{
    "name": "tr-data-escrow",
    "version": "2.1.2",
    "description": "Cryptographic escrow of JSON data and files into a filesystem vault. Data and file keys are encrypted to a public escrow key (RSA-OAEP or ECDH-ES) as JWE; files are streamed AES-256-GCM. Each escrow is a self-contained, atomically placed directory.",
    "keywords": [
        "escrow",
        "encryption",
        "jwe",
        "jwk",
        "vault",
        "crypto",
        "gdpr",
        "archive"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./decrypt": {
            "types": "./dist/decrypt.d.ts",
            "default": "./dist/decrypt.js"
        }
    },
    "bin": {
        "escrow": "dist/cli.js",
        "decrypt-escrow": "dist/decrypt-cli.js"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "JWE-KEY-EMBEDDING.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "pretest": "npm run build",
        "test": "vitest run",
        "prepack": "npm run build"
    },
    "dependencies": {
        "optist": "^2.0.1",
        "tr-jwe": "^1.1.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "tr-jwk": "^1.1.0",
        "typescript": "^5.4.0",
        "vitest": "^4.1.8"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rinne/node-tr-data-escrow.git"
    },
    "author": {
        "name": "Timo J. Rinne",
        "email": "tri@iki.fi",
        "url": "https://github.com/rinne/"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/rinne/node-tr-data-escrow/issues"
    },
    "homepage": "https://github.com/rinne/node-tr-data-escrow#readme"
}
